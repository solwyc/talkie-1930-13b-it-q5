diff --git a/tools/talkie-logits/talkie-logits.cpp b/tools/talkie-logits/talkie-logits.cpp
new file mode 100644
index 0000000..c3b1f5d
--- /dev/null
+++ b/tools/talkie-logits/talkie-logits.cpp
@@ -0,0 +1,242 @@
+#include "llama.h"
+
+#include <algorithm>
+#include <cctype>
+#include <clocale>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <fstream>
+#include <iterator>
+#include <numeric>
+#include <string>
+#include <vector>
+
+static void print_usage(char ** argv) {
+    std::fprintf(stderr,
+            "usage: %s -m model.gguf [-f prompt.txt | -p prompt] [-ngl layers] [--top-k n] [--ctx n]\n",
+            argv[0]);
+}
+
+static bool read_file(const std::string & path, std::string & out) {
+    std::ifstream file(path, std::ios::binary);
+    if (!file) {
+        return false;
+    }
+
+    out.assign(std::istreambuf_iterator<char>(file), std::istreambuf_iterator<char>());
+    return true;
+}
+
+static std::string escaped_piece(const llama_vocab * vocab, llama_token id) {
+    std::string buf(128, '\0');
+    int n = llama_token_to_piece(vocab, id, buf.data(), (int) buf.size(), 0, true);
+    if (n < 0) {
+        buf.assign((size_t) -n, '\0');
+        n = llama_token_to_piece(vocab, id, buf.data(), (int) buf.size(), 0, true);
+    }
+    if (n < 0) {
+        return "<piece-error>";
+    }
+
+    buf.resize((size_t) n);
+
+    std::string out;
+    out.reserve(buf.size());
+    for (unsigned char ch : buf) {
+        switch (ch) {
+            case '\n': out += "\\n"; break;
+            case '\r': out += "\\r"; break;
+            case '\t': out += "\\t"; break;
+            case '\\': out += "\\\\"; break;
+            case '"':  out += "\\\""; break;
+            default:
+                if (std::isprint(ch)) {
+                    out.push_back((char) ch);
+                } else {
+                    char tmp[8];
+                    std::snprintf(tmp, sizeof(tmp), "\\x%02X", ch);
+                    out += tmp;
+                }
+                break;
+        }
+    }
+
+    return out.empty() ? "<empty>" : out;
+}
+
+struct candidate {
+    llama_token id;
+    float logit;
+};
+
+static std::vector<candidate> top_logits(const float * logits, int n_vocab, int top_k) {
+    std::vector<int> ids((size_t) n_vocab);
+    std::iota(ids.begin(), ids.end(), 0);
+
+    const int k = std::min(top_k, n_vocab);
+    std::partial_sort(ids.begin(), ids.begin() + k, ids.end(), [&](int a, int b) {
+        return logits[a] > logits[b];
+    });
+
+    std::vector<candidate> out;
+    out.reserve((size_t) k);
+    for (int i = 0; i < k; ++i) {
+        const int id = ids[(size_t) i];
+        out.push_back({ id, logits[id] });
+    }
+    return out;
+}
+
+static void print_top(const char * label, const llama_vocab * vocab, const float * logits, int n_vocab, int top_k) {
+    if (!logits) {
+        std::printf("  %s: <null>\n", label);
+        return;
+    }
+
+    const auto top = top_logits(logits, n_vocab, top_k);
+    std::printf("  %s:\n", label);
+    for (size_t i = 0; i < top.size(); ++i) {
+        std::printf("    %2zu id=%6d logit=%9.4f piece=\"%s\"\n",
+                i + 1, top[i].id, top[i].logit, escaped_piece(vocab, top[i].id).c_str());
+    }
+}
+
+int main(int argc, char ** argv) {
+    std::setlocale(LC_NUMERIC, "C");
+
+    std::string model_path;
+    std::string prompt = "<|user|>What is your name?<|end|><|assistant|>";
+    std::string prompt_file;
+    int ngl = 99;
+    int top_k = 12;
+    int n_ctx = 128;
+    bool add_special = false;
+    bool parse_special = true;
+
+    for (int i = 1; i < argc; ++i) {
+        if (std::strcmp(argv[i], "-m") == 0 && i + 1 < argc) {
+            model_path = argv[++i];
+        } else if (std::strcmp(argv[i], "-p") == 0 && i + 1 < argc) {
+            prompt = argv[++i];
+        } else if (std::strcmp(argv[i], "-f") == 0 && i + 1 < argc) {
+            prompt_file = argv[++i];
+        } else if (std::strcmp(argv[i], "-ngl") == 0 && i + 1 < argc) {
+            ngl = std::atoi(argv[++i]);
+        } else if (std::strcmp(argv[i], "--top-k") == 0 && i + 1 < argc) {
+            top_k = std::atoi(argv[++i]);
+        } else if (std::strcmp(argv[i], "--ctx") == 0 && i + 1 < argc) {
+            n_ctx = std::atoi(argv[++i]);
+        } else if (std::strcmp(argv[i], "--add-special") == 0) {
+            add_special = true;
+        } else if (std::strcmp(argv[i], "--no-parse-special") == 0) {
+            parse_special = false;
+        } else {
+            print_usage(argv);
+            return 1;
+        }
+    }
+
+    if (model_path.empty()) {
+        print_usage(argv);
+        return 1;
+    }
+
+    if (!prompt_file.empty() && !read_file(prompt_file, prompt)) {
+        std::fprintf(stderr, "failed to read prompt file: %s\n", prompt_file.c_str());
+        return 1;
+    }
+
+    ggml_backend_load_all();
+
+    llama_model_params model_params = llama_model_default_params();
+    model_params.n_gpu_layers = ngl;
+
+    llama_model * model = llama_model_load_from_file(model_path.c_str(), model_params);
+    if (!model) {
+        std::fprintf(stderr, "failed to load model: %s\n", model_path.c_str());
+        return 1;
+    }
+
+    const llama_vocab * vocab = llama_model_get_vocab(model);
+    const int n_vocab = llama_vocab_n_tokens(vocab);
+
+    const int n_prompt = -llama_tokenize(vocab, prompt.c_str(), (int) prompt.size(), nullptr, 0, add_special, parse_special);
+    if (n_prompt <= 0) {
+        std::fprintf(stderr, "failed to estimate prompt token count\n");
+        llama_model_free(model);
+        return 1;
+    }
+
+    std::vector<llama_token> tokens((size_t) n_prompt);
+    const int n_tok = llama_tokenize(vocab, prompt.c_str(), (int) prompt.size(), tokens.data(), n_prompt, add_special, parse_special);
+    if (n_tok < 0) {
+        std::fprintf(stderr, "failed to tokenize prompt\n");
+        llama_model_free(model);
+        return 1;
+    }
+    tokens.resize((size_t) n_tok);
+
+    n_ctx = std::max(n_ctx, (int) tokens.size() + 8);
+
+    llama_context_params ctx_params = llama_context_default_params();
+    ctx_params.n_ctx = (uint32_t) n_ctx;
+    ctx_params.n_batch = (uint32_t) tokens.size();
+    ctx_params.n_ubatch = (uint32_t) tokens.size();
+    ctx_params.no_perf = false;
+
+    llama_context * ctx = llama_init_from_model(model, ctx_params);
+    if (!ctx) {
+        std::fprintf(stderr, "failed to create context\n");
+        llama_model_free(model);
+        return 1;
+    }
+
+    llama_batch batch = llama_batch_init((int32_t) tokens.size(), 0, 1);
+    for (size_t i = 0; i < tokens.size(); ++i) {
+        batch.token[i] = tokens[i];
+        batch.pos[i] = (llama_pos) i;
+        batch.n_seq_id[i] = 1;
+        batch.seq_id[i][0] = 0;
+        batch.logits[i] = 1;
+    }
+    batch.n_tokens = (int32_t) tokens.size();
+
+    const int decode_status = llama_decode(ctx, batch);
+    if (decode_status != 0) {
+        std::fprintf(stderr, "llama_decode failed: %d\n", decode_status);
+        llama_batch_free(batch);
+        llama_free(ctx);
+        llama_model_free(model);
+        return 1;
+    }
+
+    float * all_logits = llama_get_logits(ctx);
+
+    std::printf("model=%s\n", model_path.c_str());
+    std::printf("ngl=%d n_ctx=%d top_k=%d add_special=%s parse_special=%s\n",
+            ngl, n_ctx, top_k, add_special ? "true" : "false", parse_special ? "true" : "false");
+    std::printf("prompt=%s\n", prompt.c_str());
+    std::printf("tokens=%zu vocab=%d\n", tokens.size(), n_vocab);
+    for (size_t i = 0; i < tokens.size(); ++i) {
+        std::printf("  [%zu] id=%6d piece=\"%s\"\n", i, tokens[i], escaped_piece(vocab, tokens[i]).c_str());
+    }
+
+    for (size_t i = 0; i < tokens.size(); ++i) {
+        const float * raw = all_logits ? all_logits + i * (size_t) n_vocab : nullptr;
+        const float * ith = llama_get_logits_ith(ctx, (int32_t) i);
+        std::printf("\nrow=%zu input_id=%d input_piece=\"%s\"\n",
+                i, tokens[i], escaped_piece(vocab, tokens[i]).c_str());
+        print_top("raw-contiguous", vocab, raw, n_vocab, top_k);
+        if (ith != raw) {
+            print_top("llama_get_logits_ith", vocab, ith, n_vocab, top_k);
+        }
+    }
+
+    llama_batch_free(batch);
+    llama_free(ctx);
+    llama_model_free(model);
+    llama_backend_free();
+
+    return 0;
+}
