     auto it = pimpl->bpe_ranks.find(std::make_pair(token_left, token_right));
     if (it == pimpl->bpe_ranks.end()) {
-        return -1;
+        if (!pimpl->bpe_ranks_from_tokens) {
+            return -1;
+        }
+
+        auto token_it = pimpl->token_to_id.find(token_left + token_right);
+        if (token_it == pimpl->token_to_id.end()) {
+            return -1;
+        }
+
+        return token_it->second;
     }
 
     return it->second;
